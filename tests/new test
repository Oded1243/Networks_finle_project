# RUDP Library Edge Case Tests
# ==========================================

class TestRUDPEdgeCases:
    
    def test_packet_smaller_than_header(self):
        """Edge Case: Parsing a packet that is smaller than the 13-byte header."""
        # rudp_lib returns None if len(packet_bytes) < HEADER_SIZE
        too_small_packet = b'\x00' * 10
        assert rudp_lib.parse_packet(too_small_packet) is None

    def test_corrupted_checksum(self):
        """Edge Case: Data tampered with in transit (checksum mismatch)."""
        packet = rudp_lib.create_packet(1, 0, rudp_lib.FLAG_DATA, 2048, b"Valid Payload")
        
        # Tamper with the payload (change the last byte)
        corrupted_packet = bytearray(packet)
        corrupted_packet[-1] = corrupted_packet[-1] ^ 0xFF 
        
        # parse_packet should calculate a different checksum and return None
        assert rudp_lib.parse_packet(bytes(corrupted_packet)) is None

    def test_zero_byte_payload(self):
        """Edge Case: Sending an RUDP packet with exactly 0 bytes of data (e.g., pure ACK/SYN)."""
        packet = rudp_lib.create_packet(100, 50, rudp_lib.FLAG_ACK, 2048, b"")
        parsed = rudp_lib.parse_packet(packet)
        
        assert parsed is not None
        seq, ack, flags, window, data = parsed
        assert data == b""
        assert flags == rudp_lib.FLAG_ACK
        assert seq == 100
        assert ack == 50

    def test_massive_payload(self):
        """Edge Case: Maximum possible payload size."""
        # 60,000 bytes as defined by MAX_PAYLOAD_SIZE in your library
        large_data = b"A" * rudp_lib.MAX_PAYLOAD_SIZE 
        packet = rudp_lib.create_packet(1, 0, rudp_lib.FLAG_DATA, 2048, large_data)
        parsed = rudp_lib.parse_packet(packet)
        
        assert parsed is not None
        assert len(parsed[4]) == rudp_lib.MAX_PAYLOAD_SIZE


