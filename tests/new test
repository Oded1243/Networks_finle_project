@pytest.fixture(scope="module", autouse=True)
def test_server():
    """Sets up the storage DB and runs the TCP server in a background thread."""
    setup_storage()
    server_thread = threading.Thread(target=start_tcp_server, daemon=True)
    server_thread.start()
    time.sleep(1) # Give the server a moment to bind to the port
    yield

def send_tcp_request(request_str):
    """Helper to send a string to the local TCP server and return the response."""
    client_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    client_socket.settimeout(2.0)
    try:
        client_socket.connect(("127.0.0.1", OBJ_TCP_PORT))
        client_socket.send(request_str.encode("utf-8"))
        response = client_socket.recv(4096).decode("utf-8")
        return response
    finally:
        client_socket.close()

class TestServerEdgeCases:

    def test_malformed_get_request(self):
        """Edge Case: Sending a GET request without specifying a key."""
        # Server expects len(parts) >= 2
        response = send_tcp_request("GET ")
        assert "ERROR Usage: GET <key>" in response

    def test_malformed_put_request(self):
        """Edge Case: Sending a PUT request without specifying file size."""
        # Server expects len(parts) >= 3 (PUT <key> <size>)
        response = send_tcp_request("PUT my_file.txt")
        assert "ERROR Usage: PUT <key> <size>" in response

    def test_malformed_delete_request(self):
        """Edge Case: Sending a DELETE request without a key."""
        # Server expects len(parts) >= 2
        response = send_tcp_request("DELETE ")
        assert "ERROR Usage: DELETE <key>" in response

    def test_delete_nonexistent_file(self):
        """Edge Case: Deleting a file that doesn't exist in the database."""
        response = send_tcp_request("DELETE definitely_does_not_exist.txt")
        assert "ERROR Object not found" in response

    def test_get_nonexistent_file(self):
        """Edge Case: Fetching a file that doesn't exist."""
        response = send_tcp_request("GET ghost_file.bin")
        assert "ERROR Object not found" in response
        
    def test_put_with_invalid_size(self):
        """Edge Case: Sending a PUT request where the size is not an integer."""
        # Server tries to cast int(parts[2]), which will throw a ValueError
        response = send_tcp_request("PUT file.txt NOT_AN_INT")
        # In your server code, this gets caught by the top-level except block and connection dies,
        # or by the inner exception block which sends an error back.
        assert "ERROR" in response or response == ""
